<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <!-- Titre -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mode En Ligne"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp"/>

    <!-- Bouton : créer une nouvelle partie -->
    <Button
        android:id="@+id/btnCreate"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Créer une partie"
        android:textSize="16sp"
        android:layout_marginBottom="32dp"/>

    <!-- Séparateur -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="── OU ──"
        android:textColor="#888888"
        android:layout_marginBottom="24dp"/>

    <!-- Champ : entrer le code de l'ami -->
    <EditText
        android:id="@+id/editCode"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:hint="Entrer le code (ex: XY4K)"
        android:inputType="textCapCharacters"
        android:maxLength="4"
        android:gravity="center"
        android:textSize="20sp"
        android:layout_marginBottom="12dp"/>

    <!-- Bouton : rejoindre une partie existante -->
    <Button
        android:id="@+id/btnJoin"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Rejoindre une partie"
        android:textSize="16sp"/>

</LinearLayout>