<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_game.xml
    Emplacement : app/src/main/res/layout/activity_game.xml

    DÉPENDANCE GRADLE (app/build.gradle) :
        implementation 'androidx.gridlayout:gridlayout:1.0.0'
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_main">

    <!-- ── BARRE SUPÉRIEURE ── -->
    <LinearLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="16dp" android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_quit"
            android:layout_width="90dp"
            android:layout_height="40dp"
            android:text="@string/game_btn_quit"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/color_primary"
            android:background="@drawable/button_secondary"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:includeFontPadding="false"
            android:stateListAnimator="@null" />

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_round_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Partie 1 / 5"
            android:textSize="16sp" android:textStyle="bold"
            android:textColor="@color/color_text_primary" />
    </LinearLayout>

    <!-- ── SCORES ── -->
    <LinearLayout
        android:id="@+id/layout_scores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/layout_top_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- X -->
        <LinearLayout android:id="@+id/card_score_x"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/score_card_background" android:padding="12dp"
            android:layout_marginEnd="5dp">
            <TextView android:id="@+id/tv_score_x_value"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="34sp" android:textStyle="bold"
                android:textColor="@color/color_player_x" android:gravity="center" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/game_score_x" android:textSize="11sp"
                android:textAllCaps="true" android:letterSpacing="0.1"
                android:textColor="@color/color_player_x" android:gravity="center" />
        </LinearLayout>

        <!-- Nuls -->
        <LinearLayout android:id="@+id/card_score_draw"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="0.9" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/score_card_background" android:padding="12dp"
            android:layout_marginStart="5dp" android:layout_marginEnd="5dp">
            <TextView android:id="@+id/tv_score_draw_value"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="34sp" android:textStyle="bold"
                android:textColor="@color/color_draw" android:gravity="center" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/game_score_draw" android:textSize="10sp"
                android:textAllCaps="true" android:letterSpacing="0.08"
                android:textColor="@color/color_draw" android:gravity="center" />
        </LinearLayout>

        <!-- O -->
        <LinearLayout android:id="@+id/card_score_o"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:background="@drawable/score_card_background" android:padding="12dp"
            android:layout_marginStart="5dp">
            <TextView android:id="@+id/tv_score_o_value"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textSize="34sp" android:textStyle="bold"
                android:textColor="@color/color_player_o" android:gravity="center" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/game_score_o" android:textSize="11sp"
                android:textAllCaps="true" android:letterSpacing="0.1"
                android:textColor="@color/color_player_o" android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── INDICATEUR DE TOUR ── -->
    <LinearLayout
        android:id="@+id/layout_turn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/panel_background"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="10dp" android:paddingBottom="10dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/layout_scores"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/game_turn_label"
            android:textSize="14sp" android:textColor="@color/color_text_secondary"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tv_current_turn"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/game_player_x"
            android:textSize="16sp" android:textStyle="bold"
            android:textColor="@color/color_player_x" />
    </LinearLayout>

    <!-- ── GRILLE 3×3 ── -->
    <androidx.gridlayout.widget.GridLayout
        android:id="@+id/grid_game"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp" android:layout_marginEnd="20dp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/layout_turn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:rowCount="3"
        app:columnCount="3">

        <Button android:id="@+id/cell_1"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center" android:layout_margin="5dp"
            app:layout_columnWeight="1" app:layout_rowWeight="1" />
        <Button android:id="@+id/cell_2"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center" android:layout_margin="5dp"
            app:layout_columnWeight="1" app:layout_rowWeight="1" />
        <Button android:id="@+id/cell_3"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center" android:layout_margin="5dp"
            app:layout_columnWeight="1" app:layout_rowWeight="1" />
        <Button android:id="@+id/cell_4"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center" android:layout_margin="5dp"
            app:layout_columnWeight="1" app:layout_rowWeight="1" />
        <Button android:id="@+id/cell_5"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center" android:layout_margin="5dp"
            app:layout_columnWeight="1" app:layout_rowWeight="1" />
        <Button android:id="@+id/cell_6"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center" android:layout_margin="5dp"
            app:layout_columnWeight="1" app:layout_rowWeight="1" />
        <Button android:id="@+id/cell_7"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center" android:layout_margin="5dp"
            app:layout_columnWeight="1" app:layout_rowWeight="1" />
        <Button android:id="@+id/cell_8"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center" android:layout_margin="5dp"
            app:layout_columnWeight="1" app:layout_rowWeight="1" />
        <Button android:id="@+id/cell_9"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center" android:layout_margin="5dp"
            app:layout_columnWeight="1" app:layout_rowWeight="1" />
    </androidx.gridlayout.widget.GridLayout>

    <!-- ── ZONE VOCALE ── -->
    <LinearLayout
        android:id="@+id/layout_voice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/grid_game"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_mic"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="🎤"
            android:textSize="26sp"
            android:background="@drawable/mic_button_background"
            android:stateListAnimator="@null"
            android:gravity="center"
            android:padding="0dp"
            android:contentDescription="Jouer par voix" />

        <TextView
            android:id="@+id/tv_mic_label"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/game_btn_mic"
            android:textSize="13sp" android:textColor="@color/color_primary"
            android:gravity="center" android:layout_marginTop="6dp" />


        <TextView
            android:id="@+id/tv_listening"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/game_listening"
            android:textSize="13sp" android:textStyle="bold"
            android:textColor="@color/color_player_x"
            android:gravity="center" android:layout_marginTop="4dp"
            android:visibility="gone" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
