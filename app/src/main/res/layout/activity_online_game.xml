<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_main">

    <!-- ── BARRE SUPÉRIEURE ── -->
    <LinearLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_quit_online"
            android:layout_width="90dp"
            android:layout_height="48dp"
            android:text="Quitter"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/color_primary"
            android:background="@drawable/button_secondary"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:includeFontPadding="false"
            android:stateListAnimator="@null"
            android:contentDescription="Quitter la partie"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvCurrentTurn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Partie 1 / 5"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"/>

    </LinearLayout>

    <!-- ── SCORES ── -->
    <LinearLayout
        android:id="@+id/layout_scores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/layout_top_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Score X -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/score_card_background"
            android:padding="12dp"
            android:layout_marginEnd="5dp">

            <TextView
                android:id="@+id/tvScoreX"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="@color/color_player_x"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JOUEUR X"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textColor="@color/color_player_x"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Score Nuls -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/score_card_background"
            android:padding="12dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp">

            <TextView
                android:id="@+id/tvScoreDraw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="@color/color_draw"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NULS"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:textColor="@color/color_draw"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Score O -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/score_card_background"
            android:padding="12dp"
            android:layout_marginStart="5dp">

            <TextView
                android:id="@+id/tvScoreO"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="@color/color_player_o"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JOUEUR O"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textColor="@color/color_player_o"
                android:gravity="center"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ── INDICATEUR DE TOUR ── -->
    <LinearLayout
        android:id="@+id/layout_turn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/panel_background"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/layout_scores"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tour : "
            android:textSize="14sp"
            android:textColor="@color/color_text_secondary"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/tvTourJoueur"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="X"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/color_player_x"/>

    </LinearLayout>

    <!-- ── CODE DE LA ROOM ── -->
    <TextView
        android:id="@+id/tvRoomCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Room : ????"
        android:textSize="12sp"
        android:textColor="@color/color_text_secondary"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/layout_turn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── GRILLE 3x3 ── -->
    <androidx.gridlayout.widget.GridLayout
        android:id="@+id/grid_game"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvRoomCode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:rowCount="3"
        app:columnCount="3">

        <Button android:id="@+id/cell0"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center"
            android:layout_margin="5dp"
            android:contentDescription="Case 1"
            app:layout_columnWeight="1" app:layout_rowWeight="1"/>

        <Button android:id="@+id/cell1"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center"
            android:layout_margin="5dp"
            android:contentDescription="Case 2"
            app:layout_columnWeight="1" app:layout_rowWeight="1"/>

        <Button android:id="@+id/cell2"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center"
            android:layout_margin="5dp"
            android:contentDescription="Case 3"
            app:layout_columnWeight="1" app:layout_rowWeight="1"/>

        <Button android:id="@+id/cell3"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center"
            android:layout_margin="5dp"
            android:contentDescription="Case 4"
            app:layout_columnWeight="1" app:layout_rowWeight="1"/>

        <Button android:id="@+id/cell4"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center"
            android:layout_margin="5dp"
            android:contentDescription="Case 5"
            app:layout_columnWeight="1" app:layout_rowWeight="1"/>

        <Button android:id="@+id/cell5"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center"
            android:layout_margin="5dp"
            android:contentDescription="Case 6"
            app:layout_columnWeight="1" app:layout_rowWeight="1"/>

        <Button android:id="@+id/cell6"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center"
            android:layout_margin="5dp"
            android:contentDescription="Case 7"
            app:layout_columnWeight="1" app:layout_rowWeight="1"/>

        <Button android:id="@+id/cell7"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center"
            android:layout_margin="5dp"
            android:contentDescription="Case 8"
            app:layout_columnWeight="1" app:layout_rowWeight="1"/>

        <Button android:id="@+id/cell8"
            android:layout_width="0dp" android:layout_height="100dp"
            android:text="" android:textSize="38sp" android:textStyle="bold"
            android:background="@drawable/cell_background"
            android:stateListAnimator="@null" android:gravity="center"
            android:layout_margin="5dp"
            android:contentDescription="Case 9"
            app:layout_columnWeight="1" app:layout_rowWeight="1"/>

    </androidx.gridlayout.widget.GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>