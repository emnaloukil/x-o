    <!-- Règles -->
    <string name="rules_title">Principe du jeu</string>
    <string name="rules_xo_title">🎮 Règles du X-O</string>
    <string name="rules_xo_text">Le jeu se joue sur une grille 3×3. Chaque joueur place son symbole (X ou O) à tour de rôle. Le premier joueur à aligner 3 symboles (horizontalement, verticalement ou en diagonale) remporte la partie. Si toutes les cases sont remplies sans vainqueur, la partie est déclarée nulle.</string>
    <string name="rules_tournament_title">🏆 Tournoi</string>
    <string name="rules_tournament_text">Un tournoi se compose de 5, 10 ou 15 parties. Les scores sont accumulés tout au long du tournoi. À la fin, le joueur avec le plus grand nombre de victoires est déclaré champion.</string>
    <string name="rules_voice_title">🎤 Commande vocale</string>
    <string name="rules_voice_text">Appuyez sur le bouton micro et dites le numéro de la case souhaitée : « case un », « case deux », …, « case neuf ». Les cases sont numérotées de gauche à droite et de haut en bas.</string>
    <string name="rules_grid_diagram">1 | 2 | 3\n—+—+—\n4 | 5 | 6\n—+—+—\n7 | 8 | 9</string>
